{
  "expo": {
    "name": "Summit Scene",
    "slug": "summit-scene",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "summitscene",
    "icon": "./assets/logo-app-full-color-square.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-app-earth-transparent-alpha.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F3EE"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Summit Scene uses your location to show events near you."
        }
      ]
    ],
    
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-app-full-color-square.png",
        "backgroundColor": "#F5F3EE"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo-app-full-color-square.png"
    }
  }
}
